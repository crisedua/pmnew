# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (asistente IA y resúmenes de reportes)
# OJO: SIN el prefijo VITE_. Lo leen las funciones serverless
# api/chat.js y api/embeddings.js vía process.env.OPENAI_API_KEY.
# Configúrala en Vercel > Settings > Environment Variables.
# Una variable VITE_OPENAI_API_KEY NO funciona (además expondría la clave al navegador).
OPENAI_API_KEY=sk-your-openai-api-key
