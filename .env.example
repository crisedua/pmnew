# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (asistente IA y resúmenes de reportes)
# La leen las funciones serverless api/chat.js y api/embeddings.js.
# En Vercel se acepta OPENAI_API_KEY o VITE_OPENAI_API_KEY: todas las
# variables del proyecto llegan a process.env en las funciones.
# Se prefiere OPENAI_API_KEY (sin prefijo) para dejar claro que es server-side.
OPENAI_API_KEY=sk-your-openai-api-key
